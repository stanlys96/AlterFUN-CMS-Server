{
  "kind": "collectionType",
  "collectionName": "creators",
  "info": {
    "singularName": "creator",
    "pluralName": "creators",
    "displayName": "Creator"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "username": {
      "type": "string",
      "unique": true
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "bio": {
      "type": "text"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category"
    },
    "subscribers": {
      "type": "string"
    },
    "views": {
      "type": "string"
    },
    "contents": {
      "type": "string"
    },
    "active_since": {
      "type": "date"
    },
    "active_time": {
      "type": "string"
    },
    "merchandises": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::merchandise.merchandise",
      "mappedBy": "creator"
    },
    "videos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::video.video",
      "mappedBy": "creator"
    },
    "chapters": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::chapter.chapter",
      "mappedBy": "creator"
    },
    "instagram": {
      "type": "string"
    },
    "discord": {
      "type": "string"
    },
    "x": {
      "type": "string"
    },
    "twitch": {
      "type": "string"
    },
    "youtube": {
      "type": "string"
    }
  }
}
