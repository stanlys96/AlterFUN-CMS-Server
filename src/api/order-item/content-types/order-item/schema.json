{
  "kind": "collectionType",
  "collectionName": "order_items",
  "info": {
    "singularName": "order-item",
    "pluralName": "order-items",
    "displayName": "Order Item"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "quantity": {
      "type": "integer"
    },
    "size": {
      "type": "string"
    },
    "order_status": {
      "type": "enumeration",
      "enum": ["pending", "processing", "shipped", "done"]
    },
    "province": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "postal_code": {
      "type": "string"
    },
    "full_address": {
      "type": "text"
    },
    "merchandise": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::merchandise.merchandise"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::registered-user.registered-user"
    }
  }
}
