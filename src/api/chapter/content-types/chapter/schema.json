{
  "kind": "collectionType",
  "collectionName": "chapters",
  "info": {
    "singularName": "chapter",
    "pluralName": "chapters",
    "displayName": "Chapter"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "background": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images", "videos", "files", "audios"]
    },
    "deadline": {
      "type": "datetime"
    },
    "creator": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::creator.creator"
    }
  }
}
