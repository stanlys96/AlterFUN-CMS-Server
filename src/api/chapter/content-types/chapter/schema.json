{
  "kind": "collectionType",
  "collectionName": "chapters",
  "info": {
    "singularName": "chapter",
    "pluralName": "chapters",
    "displayName": "Chapter"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "background": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "videos",
        "files",
        "audios"
      ]
    },
    "deadline": {
      "type": "datetime"
    },
    "creator": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::creator.creator",
      "inversedBy": "chapters"
    },
    "quests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::quest.quest",
      "mappedBy": "chapter"
    },
    "merchandises": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::merchandise.merchandise",
      "mappedBy": "chapter"
    }
  }
}
