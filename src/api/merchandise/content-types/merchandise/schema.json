{
  "kind": "collectionType",
  "collectionName": "merchandises",
  "info": {
    "singularName": "merchandise",
    "pluralName": "merchandises",
    "displayName": "Merchandise"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "price": {
      "type": "integer"
    },
    "original_price": {
      "type": "integer"
    },
    "discount": {
      "type": "integer"
    },
    "type": {
      "type": "enumeration",
      "enum": ["physical", "digital"]
    },
    "stock": {
      "type": "integer"
    },
    "sizes": {
      "type": "json"
    },
    "is_hot": {
      "type": "boolean"
    },
    "chapter": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::chapter.chapter"
    },
    "creator": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::creator.creator"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category"
    }
  }
}
